# =============================================================================
# Oh My Zsh
# =============================================================================
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"

# compinit キャッシュ
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.zsh/cache

plugins=(
  git
  zsh-syntax-highlighting
  zsh-autosuggestions
  zsh-completions
)

source $ZSH/oh-my-zsh.sh

# =============================================================================
# PATH（一括設定）
# =============================================================================
export GHQ_ROOT="$HOME/src"
export GOPATH="$HOME/go"
export VOLTA_HOME="$HOME/.volta"
export BUN_INSTALL="$HOME/.bun"
export ANDROID_HOME=$HOME/Library/Android/sdk

path=(
  $HOME/.local/bin
  $HOME/.browser-use-env/bin
  $HOME/.browser-use/bin
  ${ASDF_DATA_DIR:-$HOME/.asdf}/shims
  $VOLTA_HOME/bin
  $BUN_INSTALL/bin
  $HOME/.turso
  $HOME/.codeium/windsurf/bin
  /Applications/IntelliJ\ IDEA.app/Contents/MacOS
  $GOPATH/bin
  $HOME/development/flutter/bin
  $HOME/.pub-cache/bin
  $ANDROID_HOME/emulator
  $ANDROID_HOME/platform-tools
  $path
)
typeset -U path  # 重複排除

# =============================================================================
# ghq + fzf
# =============================================================================
export FZF_DEFAULT_OPTS="--height 50% --layout=reverse --border --inline-info --preview-window=right:60%:wrap"

function repo() {
  local selected_dir=$(ghq list -p | fzf --preview "ls -la {}" --preview-window=right:60%)
  if [ -n "$selected_dir" ]; then
    cd "$selected_dir"
  fi
}
zle -N repo
bindkey '^]' repo

function select-history() {
  BUFFER=$(history -n -r 1 | fzf --no-sort +m --query "$LBUFFER" --prompt="History > ")
  CURSOR=$#BUFFER
  zle reset-prompt
}
zle -N select-history
bindkey '^r' select-history

function vscode() {
  local repository=$(ghq list | fzf --preview "ls -la $(ghq root)/{}" --preview-window=right:60%)
  if [ -n "$repository" ]; then
    code "$(ghq root)/$repository" -r
  fi
}

function browse() {
  local selected_repo=$(ghq list | fzf --preview "ls -la $(ghq root)/{}" --preview-window=right:60%)
  if [ -n "$selected_repo" ]; then
    open "https://${selected_repo}"
  fi
}

