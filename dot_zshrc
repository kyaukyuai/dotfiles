# =============================================================================
# Kubernetes（遅延読み込み — 使うときだけ completion をロード）
# =============================================================================
function kubectl() { unfunction "$0"; source <(command kubectl completion zsh); command kubectl "$@"; }
function helm() { unfunction "$0"; source <(command helm completion zsh); command helm "$@"; }
function minikube() { unfunction "$0"; source <(command minikube completion zsh); command minikube "$@"; }
function argo() { unfunction "$0"; source <(command argo completion zsh); command argo "$@"; }

alias kc='kubectx | fzf --height 40% --reverse | xargs kubectx'
alias kn='kubens | fzf --height 40% --reverse | xargs kubens'
alias kg='kubectl get'
alias kd='kubectl describe'
alias ke='kubectl edit'
alias kl='kubectl logs'

export KUBECONFIG=${KUBECONFIG:+$KUBECONFIG:}$HOME/.kube/config

# Terraform completion
command -v terraform >/dev/null && complete -o nospace -C "$(command -v terraform)" terraform

# =============================================================================
# Tool initializations
# =============================================================================
# Starship
command -v starship >/dev/null && eval "$(starship init zsh)"

# direnv
command -v direnv >/dev/null && eval "$(direnv hook zsh)"

# SSH Agent（既に走っていなければ起動）
if [ -z "$SSH_AUTH_SOCK" ]; then
  eval $(ssh-agent -s) > /dev/null 2>&1
  ssh-add ~/.ssh/id_ed25519 2>/dev/null
fi

# GPG
export GPG_TTY=$(tty)

# gcloud
function gconf() {
  gcloud config configurations activate $1 && \
  gcloud auth application-default set-quota-project $(gcloud config get-value project)
}

# Warp
PROMPT_EOL_MARK=''

# =============================================================================
# conda（遅延読み込み）
# =============================================================================
function conda() {
  unfunction "$0"
  __conda_setup="$('/opt/homebrew/Caskroom/miniconda/base/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
  if [ $? -eq 0 ]; then
    eval "$__conda_setup"
  else
    if [ -f "/opt/homebrew/Caskroom/miniconda/base/etc/profile.d/conda.sh" ]; then
      . "/opt/homebrew/Caskroom/miniconda/base/etc/profile.d/conda.sh"
    else
      export PATH="/opt/homebrew/Caskroom/miniconda/base/bin:$PATH"
    fi
  fi
  unset __conda_setup
  command conda "$@"
}

# =============================================================================
# External tool integrations
# =============================================================================
# kiro
[[ "$TERM_PROGRAM" == "kiro" ]] && . "$(kiro --locate-shell-integration-path zsh)"

# wt (Warp Terminal)
if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

# daytona
