// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "vim_mode": true,
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-5"
    },
    "model_parameters": []
  },
  "terminal": {
    "font_size": 13.0,
    "font_family": "Droid Sans Mono for Powerline"
  },
  "minimap": {
    "show": "never"
  },
  "buffer_font_fallbacks": [
    "Cascadia Code",
    "Fira Code",
    "Consolas",
    "Courier New",
    "monospace"
  ],
  "buffer_font_family": "Droid Sans Mono for Powerline",
  "show_whitespaces": "selection",
  "ensure_final_newline_on_save": true,
  "wrap_guides": [
    88,
    100
  ],
  "soft_wrap": "editor_width",
  "hard_tabs": false,
  "tab_size": 4,
  "base_keymap": "VSCode",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Catppuccin Mocha"
  },
  "ui_font_size": 16,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Gruvbox Dark Hard"
  }
}
